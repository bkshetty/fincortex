generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Business {
  id               String   @id @default(uuid())
  name             String
  turnover         Float    @default(0)
  entity_type      String   // proprietorship, partnership, etc.
  gst_scheme       String   // regular, composition
  sector           String
  created_at       DateTime @default(now())
  
  expenses         Expense[]
  employees        Employee[]
  assets           Asset[]
  recommendations  TaxRecommendation[]
  notifications    CANotification[]
  invoices         Invoice[]
}

model Expense {
  id          String   @id @default(uuid())
  business_id String
  business    Business @relation(fields: [business_id], references: [id])
  category    String
  amount      Float
  date        DateTime @default(now())
  created_at  DateTime @default(now())
}

model Employee {
  id          String   @id @default(uuid())
  business_id String
  business    Business @relation(fields: [business_id], references: [id])
  name        String?
  hired_at    DateTime @default(now())
  salary      Float
  created_at  DateTime @default(now())
}

model Asset {
  id          String   @id @default(uuid())
  business_id String
  business    Business @relation(fields: [business_id], references: [id])
  name        String?
  category    String   // machinery, equipment, computer, vehicle
  value       Float
  purchased_at DateTime @default(now())
  created_at  DateTime @default(now())
}

model TaxRule {
  id               String   @id @default(uuid())
  rule_code        String   @unique
  section_name     String
  description      String
  condition_type   String
  condition_value  Json
  max_benefit_text String
  category         String
  created_at       DateTime @default(now())
  
  recommendations  TaxRecommendation[]
}

model TaxRecommendation {
  id                   String   @id @default(uuid())
  business_id          String
  business             Business @relation(fields: [business_id], references: [id])
  rule_id              String
  rule                 TaxRule  @relation(fields: [rule_id], references: [id])
  status               String   @default("new") // new, flagged_to_ca, applied, dismissed
  estimated_saving_inr Float    @default(0)
  ai_explanation       String?
  priority             String   @default("medium") // high, medium, low
  action_label         String?
  triggered_by         String?
  flagged_at           DateTime?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  
  @@unique([business_id, rule_id])
}

model CANotification {
  id                String   @id @default(uuid())
  business_id       String
  business          Business @relation(fields: [business_id], references: [id])
  recommendation_id String?
  message           String
  is_read           Boolean  @default(false)
  created_at        DateTime @default(now())
}

model Invoice {
  id                       String   @id @default(uuid())
  created_at               DateTime @default(now())
  business_id              String?
  business                 Business? @relation(fields: [business_id], references: [id])
  vendor_name              String
  vendor_gstin             String?
  invoice_number           String
  invoice_date             String
  payment_due_date         DateTime?
  currency                 String
  currency_symbol          String?
  subtotal                 Float
  tax_amount               Float
  total_amount             Float
  tax_type                 String
  effective_tax_rate       Float
  cgst_amount              Float?
  sgst_amount              Float?
  igst_amount              Float?
  cess_amount              Float?
  cgst_rate                Float?
  sgst_rate                Float?
  igst_rate                Float?
  cess_rate                Float?
  mixed_tax_rates_detected  Boolean? @default(false)
  tax_mismatch             Boolean? @default(false)
  tax_mismatch_percent     Float?
  currency_inconsistency   Boolean? @default(false)
  risk_score               String
  compliance_advisor       Json?
  fraud_signals            Json?
  draft_vendor_email       Json?
  image_hash               String?
  image_url                String?
  payment_status           String?  @default("PENDING")
  notification_sent        Boolean? @default(false)

  @@index([invoice_number, vendor_name])
  @@index([image_hash])
}
